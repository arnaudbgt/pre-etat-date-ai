# Supabase local (valeurs affichees par `npm run db:status`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Ne jamais préfixer cette clé avec NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Session anonyme d'upload (32 caractères minimum)
UPLOAD_SESSION_SECRET=

# Limites applicatives. MAX_PDF_SIZE_MB doit rester inférieur ou égal à 50.
MAX_PDF_SIZE_MB=10
MAX_PDF_FILES=10
TEMP_UPLOAD_RETENTION_HOURS=24
PURGE_BATCH_SIZE=100

# Classification locale du texte PDF
CLASSIFICATION_MAX_PAGES=50
CLASSIFICATION_MAX_CHARACTERS=200000
CLASSIFICATION_MIN_CHARACTERS=80

# Secret envoyé automatiquement par Vercel Cron
CRON_SECRET=
